# 环境变量配置模板
# 复制此文件为 .env 并填入真实值

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=nexus_demo
DB_USERNAME=root
DB_PASSWORD=your_db_password_here

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT配置（生成一个Base64密钥）
JWT_SECRET=your_base64_secret_key_here

# DeepSeek API配置
DEEPSEEK_API_KEY=your_deepseek_api_key_here
USE_LLM=true