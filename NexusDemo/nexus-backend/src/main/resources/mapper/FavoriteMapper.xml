<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.nexus.mapper.FavoriteMapper">

    <resultMap id="BaseResultMap" type="com.nexus.model.entity.Favorite">
        <id column="id" property="id"/>
        <result column="member_id" property="memberId"/>
        <result column="product_id" property="productId"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, member_id, product_id, create_time, update_time
    </sql>

    <!-- 插入收藏 -->
    <insert id="insert" parameterType="com.nexus.model.entity.Favorite" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO ums_favorite (member_id, product_id)
        VALUES (#{memberId}, #{productId})
    </insert>

    <!-- 根据ID删除收藏 -->
    <delete id="deleteById">
        DELETE FROM ums_favorite WHERE id = #{id}
    </delete>

    <!-- 根据会员ID和商品ID删除收藏 -->
    <delete id="deleteByMemberIdAndProductId">
        DELETE FROM ums_favorite WHERE member_id = #{memberId} AND product_id = #{productId}
    </delete>

    <!-- 根据ID查询收藏 -->
    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM ums_favorite
        WHERE id = #{id}
    </select>

    <!-- 根据会员ID和商品ID查询收藏 -->
    <select id="selectByMemberIdAndProductId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM ums_favorite
        WHERE member_id = #{memberId} AND product_id = #{productId}
    </select>

    <!-- 根据会员ID查询所有收藏 -->
    <select id="selectByMemberId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM ums_favorite
        WHERE member_id = #{memberId}
        ORDER BY create_time DESC
    </select>

    <!-- 根据会员ID分页查询收藏 -->
    <select id="selectByMemberIdPage" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM ums_favorite
        WHERE member_id = #{memberId}
        ORDER BY create_time DESC
        LIMIT #{offset}, #{limit}
    </select>

    <!-- 统计会员收藏数量 -->
    <select id="countByMemberId" resultType="java.lang.Long">
        SELECT COUNT(*) FROM ums_favorite WHERE member_id = #{memberId}
    </select>

    <!-- 检查会员是否收藏了某商品 -->
    <select id="existsByMemberIdAndProductId" resultType="boolean">
        SELECT COUNT(*) > 0 FROM ums_favorite
        WHERE member_id = #{memberId} AND product_id = #{productId}
    </select>

</mapper>